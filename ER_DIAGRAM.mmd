      C_BOT4([Country]):::attr
      C_BOT5([State]):::attr
      C_BOT6([City]):::attr
      C_BOT7([Pincode]):::attr

      CUST --- C_TOP1
      CUST --- C_TOP2
      CUST --- C_TOP3
      CUST --- C_TOP4
      CUST --- C_TOP5
      CUST --- C_BOT1
      CUST --- C_BOT2
      CUST --- C_BOT3
      CUST --- C_BOT4
      CUST --- C_BOT5
